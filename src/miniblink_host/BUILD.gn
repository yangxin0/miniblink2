# mb_gl_probe: WebGL bring-up milestone A — initializes ANGLE/SwiftShader GL
# IN-PROCESS and makes an offscreen context current. Blink-free: links only the GL
# stack, so a green run isolates "the in-process GL foundation works" ahead of the
# (heavier) in-process command buffer + blink WebGL provider.
executable("mb_gl_probe") {
  sources = [ "tools/mb_gl_probe.cc" ]
  deps = [
    "//base",
    "//ui/gfx/geometry",
    "//ui/gl",
    "//ui/gl/init",
  ]
}

# mb_gpu_probe: WebGL bring-up milestone B — an in-process GPU command buffer over the
# milestone-A GL, driven through a real gpu::gles2::GLES2Interface (what blink's WebGL
# provider consumes). Blink-free.
executable("mb_gpu_probe") {
  testonly = true  # //gpu/ipc:gl_in_process_context + :gpu_thread_holder are testonly
  sources = [ "tools/mb_gpu_probe.cc" ]
  deps = [
    "//base",
    "//gpu/command_buffer/client:gles2_implementation",
    "//gpu/command_buffer/client:gles2_interface",
    "//gpu/command_buffer/common",
    "//gpu/config",
    "//gpu/ipc:gl_in_process_context",
    "//gpu/ipc:gpu_thread_holder",
    "//ui/gl",
    "//ui/gl/init",
  ]
}

# mb_dawn_probe: WebGPU bring-up milestone A — an in-process Dawn native instance that
# enumerates adapters and creates a real WebGPU device (SwiftShader fallback preferred).
# Blink-free, so a green run isolates "the in-process Dawn foundation works" ahead of the
# heavier blink WebGPU provider wiring. Mirrors mb_gl_probe's role for the GL stack.
executable("mb_dawn_probe") {
  sources = [ "tools/mb_dawn_probe.cc" ]
  deps = [
    "//base",
    "//third_party/dawn/src/dawn/native",
  ]
}

# mb_webgpu_probe: WebGPU bring-up milestone B — an in-process WebGPU command buffer over
# the milestone-A Dawn device, driven through gpu::webgpu::WebGPUInterface + the dawn-wire
# client (what blink's WebGPU provider consumes). Requests an adapter + device through the
# wire. Blink-free; testonly because WebGPUInProcessContext lives in //gpu:test_support.
executable("mb_webgpu_probe") {
  testonly = true
  sources = [ "tools/mb_webgpu_probe.cc" ]
  deps = [
    "//base",
    "//base/test:test_support",
    "//components/viz/test:test_support",
    "//gpu:test_support",
    "//gpu/command_buffer/client:webgpu",
    "//gpu/command_buffer/client:webgpu_interface",
    "//gpu/webgpu:common",
    "//mojo/core/embedder",
    "//third_party/dawn/include/dawn:cpp_headers",
    "//third_party/dawn/src/dawn:proc",
    "//third_party/dawn/src/dawn/wire",
    "//ui/gl",
    "//ui/gl/init",
  ]
}

# mb_webgpu2_probe: WebGPU bring-up milestone C1 — prove the PRODUCTION (non-testonly)
# in-process WebGPU context (platform/mb_webgpu_context, our copy of WebGPUInProcessContext
# using a real task runner) resolves requestAdapter/requestDevice. Links ONLY non-testonly
# deps (the in-process GPU command-buffer targets are non-testonly via patches/0006), so a
# green run means this path can be wired into the host library + MbPlatform (milestone C2).
executable("mb_webgpu2_probe") {
  sources = [
    "platform/mb_webgpu_context.cc",
    "platform/mb_webgpu_context.h",
    "tools/mb_webgpu2_probe.cc",
  ]
  deps = [
    "//base",
    "//gpu/command_buffer/client:client",
    "//gpu/command_buffer/client:webgpu",
    "//gpu/command_buffer/client:webgpu_interface",
    "//gpu/command_buffer/common",
    "//gpu/command_buffer/service",
    "//gpu/config",
    "//gpu/ipc:gl_in_process_context",
    "//gpu/ipc:gpu_thread_holder",
    "//gpu/ipc/common",
    "//third_party/dawn/include/dawn:cpp_headers",
    "//third_party/dawn/src/dawn:proc",
    "//third_party/dawn/src/dawn/native",
    "//third_party/dawn/src/dawn/wire",
    "//ui/gl",
    "//ui/gl/init",
    "//url",
  ]
}

