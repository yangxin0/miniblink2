# miniblink_host — minimal in-process Blink host (the //content replacement).
#
# DRAFT. To iterate: copy this dir to chromium-150.../miniblink_host/, add
#   group("gn_all") deps += [ "//miniblink_host" ]   (or build it directly),
# then `gn gen out/Release && ninja -C out/Release miniblink_host`.
#
# Produces a shared library exposing the extern "C" mb_capi.h ABI. The CMake
# outer shell (wke/mb, port/) links ONLY that.
#
# NOTE: this reaches into renderer-internal blink targets (web_frame_widget_impl,
# url_loader), not just //third_party/blink/public — like blink's own test support.

import("//build/config/ui.gni")

component("miniblink_host") {
  output_name = "miniblink_host"

  # Donor-tree sandbox lives at //third_party/blink/renderer/miniblink_host; this
  # makes `#include "miniblink_host/..."` resolve from there.
  # Vendored WebSocket-enabled libcurl (third_party/curl) FIRST, so <curl/curl.h>
  # and <curl/websockets.h> resolve to it rather than the SDK's WS-less system curl.
  include_dirs = [
    "/Users/yangxin/dennis/chrome/miniblink-modern/third_party/curl/include",
    "//third_party/blink/renderer",
  ]

  sources = [
    "blob/mb_blob_registry.cc",
    "blob/mb_blob_registry.h",
    "capi/mb_capi.cc",
    "capi/mb_capi.h",
    "frame/mb_broadcast_channel.cc",
    "frame/mb_broadcast_channel.h",
    "frame/mb_cache_storage.cc",
    "frame/mb_cache_storage.h",
    "frame/mb_frame_broker.cc",
    "frame/mb_frame_broker.h",
    "frame/mb_dom_storage.cc",
    "frame/mb_dom_storage.h",
    "frame/mb_frame_client.cc",
    "frame/mb_frame_client.h",
    "frame/mb_frame_origin.cc",
    "frame/mb_frame_origin.h",
    "frame/mb_indexeddb.cc",
    "frame/mb_indexeddb.h",
    "frame/mb_local_frame_host.cc",
    "frame/mb_local_frame_host.h",
    "frame/mb_lock_manager.cc",
    "frame/mb_lock_manager.h",
    "frame/mb_notification_service.cc",
    "frame/mb_notification_service.h",
    "frame/mb_opfs.cc",
    "frame/mb_opfs.h",
    "frame/mb_storage_buckets.cc",
    "frame/mb_storage_buckets.h",
    "frame/mb_websocket.cc",
    "frame/mb_websocket.h",
    "frame/mb_view_client.cc",
    "frame/mb_view_client.h",
    "loader/mb_url_loader.cc",
    "loader/mb_url_loader.h",
    "media/mb_audio_player.cc",
    "media/mb_audio_player.h",
    "platform/mb_gpu_thread.cc",
    "platform/mb_gpu_thread.h",
    "platform/mb_compositor.cc",
    "platform/mb_compositor.h",
    "platform/mb_platform.cc",
    "platform/mb_platform.h",
    "platform/mb_webgl.cc",
    "platform/mb_webgl.h",
    "platform/mb_webgpu.cc",
    "platform/mb_webgpu.h",
    "platform/mb_webgpu_context.cc",
    "platform/mb_webgpu_context.h",
    "runtime/mb_runtime.cc",
    "runtime/mb_runtime.h",
    "view/mb_webview.cc",
    "view/mb_webview.h",
    "widget/mb_widget.cc",
    "widget/mb_widget.h",
    "worker/mb_dedicated_worker_host.cc",
    "worker/mb_dedicated_worker_host.h",
    "worker/mb_shared_worker.cc",
    "worker/mb_shared_worker.h",
    "worker/mb_worker_fetch_context.cc",
    "worker/mb_worker_fetch_context.h",
    "worker/mb_worker_script.cc",
    "worker/mb_worker_script.h",
    # wke compatibility layer (staged alongside at ../wke; wraps the mb_capi ABI).
    "../wke/wke.cc",
    "../wke/wke.h",
  ]

  deps = [
    # Blink engine (public + the renderer internals the host subclasses).
    "//third_party/blink/public:blink",
    "//third_party/blink/renderer/controller:controller",
    "//third_party/blink/renderer/core:core",
    "//third_party/blink/renderer/platform:platform",
    # Substrate.
    "//base",
    "//cc",
    # In-process software compositor (platform/mb_compositor.cc): a production viz::Display
    # over a SoftwareOutputSurface + a port of ui::DirectLayerTreeFrameSink, the frame sink
    # blink's WebFrameWidgetImpl returns from AllocateNewLayerTreeFrameSink.
    "//components/viz/common",
    "//components/viz/service",
    "//services/viz/public/mojom",
    "//components/language_detection/content/common:common_blink",  # LanguageDetector broker stub
    "//components/webcrypto",  # WebCrypto impl for Platform::Crypto() (SubtleCrypto)
    "//media",  # media::AudioRendererSink / OutputDeviceStatus for CreateAudioDevice
    # <audio>/<video> container metadata (media/mb_audio_player.cc): FFmpegGlue (in
    # //media) + the FFmpeg headers directly (media/ffmpeg is visibility-restricted to
    # //media). //third_party/ffmpeg's public config adds the libav* include path.
    "//third_party/ffmpeg",
    "//cc/paint",
    # In-process WebGL (platform/mb_webgl.cc): ANGLE/SwiftShader GLES2 over an
    # in-process GPU command buffer. The two in-process targets are de-testonly'd by
    # patches/0006 so this (non-testonly) library can link them.
    "//gpu/command_buffer/client:gles2_implementation",
    "//gpu/command_buffer/common",
    "//gpu/config",
    "//gpu/ipc:gl_in_process_context",
    "//gpu/ipc:gpu_thread_holder",
    # In-process WebGPU (platform/mb_webgpu*.cc): the WebGPU command-buffer client + the
    # dawn native/wire/proc libs for the in-process client+service proc-table coordination.
    "//gpu/command_buffer/client:client",
    "//gpu/command_buffer/client:webgpu",
    "//gpu/command_buffer/client:webgpu_interface",
    "//gpu/command_buffer/service",
    "//gpu/ipc/common",
    "//third_party/dawn/include/dawn:cpp_headers",
    "//third_party/dawn/src/dawn:proc",
    "//third_party/dawn/src/dawn/native",
    "//third_party/dawn/src/dawn/wire",
    "//ui/gl",
    "//ui/gl/init",
    "//gin",
    "//mojo/core/embedder",
    "//mojo/public/cpp/bindings",
    "//mojo/public/cpp/system",
    "//skia",
    "//ui/accessibility:ax_base",
    "//ui/base",
    "//ui/display",  # ScreenInfo/ScreenInfos for the compositing widget init (mb_widget.cc)
    "//ui/gfx",
    "//ui/gfx/codec",
    "//ui/gfx/geometry",
    "//v8",
    # Networking (libcurl factory implements these mojom).
    "//services/network/public/cpp",
    "//services/network/public/mojom",
    "//services/network/public/mojom:mojom_blink",
  ]

  # libcurl for mb_url_loader. TODO(mb): point at the donor's bundled curl or a
  # vendored static lib; for now assume a system/third_party curl target.
  # libs = [ "curl" ]

  configs += [
    "//third_party/blink/renderer:config",
    "//v8:external_startup_data",  # defines V8_USE_EXTERNAL_STARTUP_DATA -> gin snapshot API
  ]

  # Vendored WebSocket-enabled libcurl (tools/build-curl-macos.sh): a dylib so its
  # OpenSSL TLS stays isolated from BoringSSL (two-level namespace). Its absolute
  # install_name lets the linked binaries find it at runtime without an rpath.
  lib_dirs = [ "/Users/yangxin/dennis/chrome/miniblink-modern/third_party/curl/lib" ]
  libs = [ "curl" ]  # -> third_party/curl/lib/libcurl.dylib (HTTP(S) + ws/wss)
}

