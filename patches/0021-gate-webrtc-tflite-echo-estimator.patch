--- a/media/webrtc/BUILD.gn
+++ b/media/webrtc/BUILD.gn
@@ -3,23 +3,33 @@
 # found in the LICENSE file.
 
 import("//media/media_options.gni")
+import("//services/webnn/features.gni")
+import("//third_party/blink/renderer/config.gni")
 import("//third_party/webrtc/webrtc.gni")
 
 component("webrtc") {
   output_name = "media_webrtc"
 
+  # miniblink (patch 0030): with the WebRTC stack off (build-lib.sh --webrtc)
+  # this shrinks to the constants + base::Feature declarations that the kept
+  # mediastream/webaudio code includes; the APM glue (audio_processor, helpers)
+  # and the webrtc link dep go.
   sources = [
-    "audio_delay_stats_reporter.cc",
-    "audio_delay_stats_reporter.h",
-    "audio_processor.cc",
-    "audio_processor.h",
     "constants.cc",
     "constants.h",
-    "helpers.cc",
-    "helpers.h",
     "webrtc_features.cc",
     "webrtc_features.h",
   ]
+  if (mb_enable_webrtc) {
+    sources += [
+      "audio_delay_stats_reporter.cc",
+      "audio_delay_stats_reporter.h",
+      "audio_processor.cc",
+      "audio_processor.h",
+      "helpers.cc",
+      "helpers.h",
+    ]
+  }
 
   defines = [ "IS_MEDIA_WEBRTC_IMPL" ]
 
@@ -27,14 +37,29 @@
     "//base",
     "//build:chromecast_buildflags",
     "//media",
-    "//third_party/webrtc_overrides:webrtc_component",
   ]
+  if (mb_enable_webrtc) {
+    deps += [ "//third_party/webrtc_overrides:webrtc_component" ]
+  } else {
+    # Header-only use of third_party/webrtc (kSampleRate48kHz, enum types in
+    # webrtc_features.h): include dirs without the link dependency.
+    configs += [ "//third_party/webrtc:common_inherited_config" ]
+  }
 
-  if (!is_fuchsia) {
+  # miniblink (patch 0021): the op resolver registers every TFLite builtin
+  # kernel; gate it (and the neural residual echo estimator that needs it —
+  # see helpers.cc) on the on-device-ML build switch, mirroring the Fuchsia
+  # size exclusion above it. tflite stays a public_dep for the
+  # FlatBufferModel* in the public API; as a static library its unreferenced
+  # objects don't reach the link.
+  if (!is_fuchsia && webnn_use_tflite) {
+    defines += [ "MB_TFLITE_ECHO_ESTIMATOR" ]
     deps += [ "//components/optimization_guide/core/inference:op_resolver" ]
   }
 
-  public_deps = [ "//third_party/tflite" ]
+  if (mb_enable_webrtc) {
+    public_deps = [ "//third_party/tflite" ]
+  }
 }
 
