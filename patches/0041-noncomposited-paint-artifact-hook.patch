+  // PushPaintArtifactToCompositor argument. Pass nullptr to clear.
+  using MbNonCompositedPaintHook = void (*)(LocalFrameView&, bool repainted);
+  static void SetMbNonCompositedPaintHookForHost(MbNonCompositedPaintHook);
