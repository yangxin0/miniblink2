   return IgnoreInputEvents(GetPage()->BrowsingContextGroupToken());
 }

+namespace {
+// miniblink host hook (see WebFrameWidgetImpl::SetLayerTreeFrameSinkHookForHost).
+WebFrameWidgetImpl::LayerTreeFrameSinkHook& MbFrameSinkHook() {
+  DEFINE_STATIC_LOCAL(WebFrameWidgetImpl::LayerTreeFrameSinkHook, hook, ());
+  return hook;
+}
+}  // namespace
+
+// static
+void WebFrameWidgetImpl::SetLayerTreeFrameSinkHookForHost(
+    LayerTreeFrameSinkHook hook) {
+  MbFrameSinkHook() = std::move(hook);
+}
+
 std::unique_ptr<cc::LayerTreeFrameSink>
 WebFrameWidgetImpl::AllocateNewLayerTreeFrameSink() {
+  if (MbFrameSinkHook())
+    return MbFrameSinkHook().Run();
   return nullptr;
 }

diff --git a/third_party/blink/renderer/core/frame/web_frame_widget_impl.h b/third_party/blink/renderer/core/frame/web_frame_widget_impl.h
