@@ -157,6 +157,16 @@ class CORE_EXPORT WebFrameWidgetImpl
       bool is_for_scalable_page);
   ~WebFrameWidgetImpl() override;

+  // miniblink host hook: supplies the cc::LayerTreeFrameSink for a compositing
+  // widget in the single-process embedder. Upstream AllocateNewLayerTreeFrameSink()
+  // returns nullptr, which routes WidgetBase to a GPU-process mojo frame sink that
+  // does not exist here; this hook lets the host return its in-process software
+  // frame sink instead. Install once before showing a compositing widget; pass a
+  // null callback to clear.
+  using LayerTreeFrameSinkHook =
+      base::RepeatingCallback<std::unique_ptr<cc::LayerTreeFrameSink>()>;
+  static void SetLayerTreeFrameSinkHookForHost(LayerTreeFrameSinkHook hook);
+
   virtual void Trace(Visitor*) const;

   // Shutdown the widget.
