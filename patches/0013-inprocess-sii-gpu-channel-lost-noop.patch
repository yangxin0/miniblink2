@@ -30,6 +30,13 @@ class GPU_GLES2_EXPORT SharedImageInterfaceInProcessBase
   // Generate the next sequence token in the process's sequence
   SyncToken GenNextSyncToken();
 
+  // miniblink-modern patch: an in-process SharedImageInterface has no GPU channel that can be
+  // lost, but cc::LayerTreeFrameSink::BindToClient (software compositing) calls these on its
