+// miniblink-modern patch: an in-process SII has no GPU channel that can be lost.
+bool SharedImageInterfaceInProcessBase::AddGpuChannelLostObserver(
+    GpuChannelLostObserver* /*observer*/) {
+  return true;
+}
+
+void SharedImageInterfaceInProcessBase::RemoveGpuChannelLostObserver(
